# ============================================================
# VCI Backend – Supabase Edition
# Copy sang .env và điền giá trị thật
# ============================================================

# SERVER
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# SUPABASE – Lấy từ supabase.com > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# JWT
JWT_SECRET=vci_jwt_secret_2026_change_this_to_something_long
JWT_EXPIRES=8h

# GOOGLE SHEETS
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SERVICE_EMAIL=vci-sheets@vci-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# EMAIL SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuyensinh@vci.edu.vn
SMTP_PASS=your_gmail_app_password

# ADMIN MẶC ĐỊNH (chạy seed lần đầu)
SEED_ADMIN_EMAIL=admin@vci.edu.vn
SEED_ADMIN_PASS=Admin@VCI2026!
SEED_ADMIN_NAME=Quản trị viên VCI
